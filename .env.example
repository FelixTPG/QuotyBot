# ── Bot ───────────────────────────────────────────────────────────────
# Bot token — Discord Developer Portal → Bot → Token
DISCORD_TOKEN=

# Application (Client) ID — Discord Developer Portal → General Information
CLIENT_ID=

# Optional: register slash commands to this guild only (updates appear
# INSTANTLY — great for development). Leave empty for global registration.
DEV_GUILD_ID=

# ── Review notification (optional) ────────────────────────────────────
# Channel where a heads-up is posted when a quote is submitted for review.
# Leave empty to skip the notification. Review itself happens in the dashboard.
REVIEW_CHANNEL_ID=
# Optional: public dashboard URL, shown as a link button in the notification.
DASHBOARD_URL=

# ── Moderation dashboard (Discord OAuth2) ─────────────────────────────
# All six below are required for the dashboard to start. If any is missing,
# the dashboard is disabled and submissions are auto-approved.
#
# OAuth2 client secret — Discord Developer Portal → OAuth2
CLIENT_SECRET=
# Guild whose members are allowed to log in
GUILD_ID=
# Role ID required to access the dashboard (user must have it in GUILD_ID)
MOD_ROLE_ID=
# Must match a redirect URI registered in the Discord OAuth2 settings, e.g.
#   dev:  http://localhost:3000/auth/callback
#   prod: https://quoty.example.com/auth/callback
OAUTH_REDIRECT_URI=
# Random secret used to sign session cookies (e.g. `openssl rand -hex 32`)
SESSION_SECRET=
# Port the dashboard listens on. The app is reverse-proxy ready, so put a
# reverse proxy (e.g. Caddy — see Caddyfile.example) in front of this for TLS.
DASHBOARD_PORT=3000
